{
    "name": "nowo-tech/seo-kit-demo-symfony8",
    "description": "Demo for Seo Kit Bundle - Symfony 8",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "/var/seo-kit-bundle",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.2,<8.6",
        "nowo-tech/seo-kit-bundle": "*",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "symfony/debug-bundle": "^8.0",
        "symfony/var-dumper": "^8.0",
        "symfony/web-profiler-bundle": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    }
}
