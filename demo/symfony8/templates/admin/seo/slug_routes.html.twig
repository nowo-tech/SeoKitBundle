{% extends 'admin/seo/layout.html.twig' %}

{% block title %}SEO Admin · Slug routes{% endblock %}

{% block body %}
    <div class="toolbar">
        <p class="note" style="margin:0;">Patterns for dynamic routes (<code>slug_routes.*</code>).</p>
        <a class="btn btn-primary" href="{{ path('admin_seo_slug_route_new') }}">New slug route</a>
    </div>
    <table>
        <thead>
            <tr>
                <th>Route</th>
                <th>Templates / patterns</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for route, cfg in slug_routes %}
                <tr>
                    <td><code>{{ route }}</code></td>
                    <td>
                        <div><span class="meta">path</span> <code>{{ cfg.path_pattern|default('—') }}</code></div>
                        <div><span class="meta">title</span> <code>{{ cfg.title_template|default('—') }}</code></div>
                        {% if cfg.locales is defined %}
                            {% for locale, loc in cfg.locales %}
                                <div><span class="mono">{{ locale }}</span> <code>{{ loc.path_pattern|default('—') }}</code></div>
                            {% endfor %}
                        {% endif %}
                    </td>
                    <td class="actions">
                        <a class="btn" href="{{ path('admin_seo_slug_route_edit', {route: route}) }}">Edit</a>
                        <form method="post" action="{{ path('admin_seo_slug_route_delete', {route: route}) }}" onsubmit="return confirm('Delete slug route {{ route }} and its slugs?');">
                            <button class="btn btn-danger" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="3">No slug routes configured.</td></tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
