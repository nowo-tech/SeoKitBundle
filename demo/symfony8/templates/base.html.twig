<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ nowo_seo_head() }}
    <style>
        body { font-family: system-ui, sans-serif; max-width: 42rem; margin: 2rem auto; padding: 0 1rem; line-height: 1.5; }
        nav a { margin-right: 1rem; }
        footer { margin-top: 2rem; color: #64748b; font-size: 0.875rem; }
    </style>
</head>
<body>
    <nav>
        <a href="{{ path('app_home') }}">Home</a>
        <a href="{{ path('app_about') }}">About</a>
        <a href="{{ path('app_blog_show', {slug: 'hello-world'}) }}">Blog sample</a>
    </nav>
    <main>
        {% block body %}{% endblock %}
    </main>
    <footer>
        <a href="/sitemap.xml">Sitemap</a> · <a href="/robots.txt">Robots</a>
    </footer>
</body>
</html>
